---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { projects } from '../../data/projects';
import { SITE_TITLE } from '../../consts';

export function getStaticPaths() {
  return projects.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const project = projects.find((p) => p.slug === slug)!;
const currentIndex = projects.findIndex((p) => p.slug === slug);
const prev = currentIndex > 0 ? projects[currentIndex - 1] : null;
const next = currentIndex < projects.length - 1 ? projects[currentIndex + 1] : null;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={`${project.title} — ${SITE_TITLE}`}
      description={project.tagline}
    />
  </head>
  <body>
    <Header />
    <main class="container">

      <!-- Back -->
      <a class="back" href="/projects">← All projects</a>

      <!-- Hero -->
      <header class="hero">
        <div class="tags">
          {project.tags.map(t => <span class="pill">{t}</span>)}
        </div>
        <h1 class="title">{project.title}</h1>
        <p class="tagline">{project.tagline}</p>
        <div class="meta-row">
          <span class="meta-item"><span class="meta-label">Role</span>{project.role}</span>
          <span class="meta-sep">·</span>
          <span class="meta-item"><span class="meta-label">Duration</span>{project.duration}</span>
        </div>
      </header>

      <!-- Highlights -->
      <div class="highlights">
        {project.highlights.map(h => (
          <div class="highlight-card">
            <span class="hl-value">{h.value}</span>
            <span class="hl-label">{h.label}</span>
          </div>
        ))}
      </div>

      <!-- Sections -->
      <div class="sections">
        {project.sections.map(s => (
          <section class="section">
            <h2 class="section-heading">{s.heading}</h2>
            {s.body.split('\n\n').map(para => <p class="section-para">{para}</p>)}
            {s.bullets && (
              <ul class="section-bullets">
                {s.bullets.map(b => <li>{b}</li>)}
              </ul>
            )}
          </section>
        ))}
      </div>

      <!-- Pagination -->
      <nav class="pagination">
        {prev ? (
          <a class="pag-link prev" href={`/projects/${prev.slug}`}>
            <span class="pag-dir">← Previous</span>
            <span class="pag-title">{prev.title}</span>
          </a>
        ) : <span />}
        {next ? (
          <a class="pag-link next" href={`/projects/${next.slug}`}>
            <span class="pag-dir">Next →</span>
            <span class="pag-title">{next.title}</span>
          </a>
        ) : <span />}
      </nav>

    </main>
    <Footer />
  </body>
</html>

<style>
  .container { max-width: 760px; margin: 0 auto; padding: 36px 32px 96px; }

  /* Back */
  .back {
    display: inline-flex;
    align-items: center;
    font-size: .88rem;
    text-decoration: none;
    color: var(--accent);
    opacity: .85;
    margin-bottom: 32px;
    transition: opacity .15s ease, transform .15s ease;
  }
  .back:hover { opacity: 1; transform: translateX(-2px); }

  /* Hero */
  .hero { margin-bottom: 32px; }
  .tags { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 14px; }
  .pill {
    font-size: .78rem;
    padding: 4px 10px;
    border: 1px solid rgba(148, 163, 184, .5);
    border-radius: 999px;
    background: rgba(15, 23, 42, .02);
    opacity: .9;
  }
  .title { margin: 0 0 12px; font-size: clamp(1.7rem, 4vw, 2.4rem); line-height: 1.1; letter-spacing: -.02em; }
  .tagline { margin: 0 0 18px; font-size: 1.06rem; opacity: .8; line-height: 1.55; max-width: 58ch; }
  .meta-row { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
  .meta-item { display: flex; align-items: center; gap: 6px; font-size: .9rem; opacity: .75; }
  .meta-label {
    font-size: .72rem;
    font-weight: 600;
    letter-spacing: .08em;
    text-transform: uppercase;
    opacity: .6;
    margin-right: 2px;
  }
  .meta-sep { opacity: .4; }

  /* Highlights */
  .highlights {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 10px;
    margin-bottom: 44px;
    padding: 20px;
    border-radius: 18px;
    border: 1px solid rgba(148, 163, 184, .45);
    background: radial-gradient(circle at top left, rgba(35,55,255,.06), transparent 60%), rgba(15,23,42,.01);
  }
  .highlight-card {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .hl-value {
    font-size: 1.55rem;
    font-weight: 700;
    letter-spacing: -.02em;
    color: var(--accent);
    line-height: 1;
  }
  .hl-label { font-size: .8rem; opacity: .65; line-height: 1.3; }

  /* Sections */
  .sections { display: grid; gap: 36px; }
  .section { border-top: 1px solid rgba(148, 163, 184, .35); padding-top: 28px; }
  .section:first-child { border-top: none; padding-top: 0; }
  .section-heading {
    margin: 0 0 14px;
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: .04em;
    text-transform: uppercase;
    opacity: .75;
    font-size: .88rem;
  }
  .section-para { margin: 0 0 .9em; line-height: 1.7; opacity: .9; }
  .section-para:last-child { margin-bottom: 0; }
  .section-bullets {
    margin: .5em 0 0;
    padding-left: 0;
    list-style: none;
    display: grid;
    gap: 10px;
  }
  .section-bullets li {
    padding-left: 1.1em;
    position: relative;
    line-height: 1.65;
    opacity: .9;
  }
  .section-bullets li::before {
    content: "—";
    position: absolute;
    left: 0;
    opacity: .4;
    font-size: .85em;
    top: .15em;
  }

  /* Pagination */
  .pagination {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    margin-top: 64px;
    padding-top: 24px;
    border-top: 1px solid rgba(148, 163, 184, .35);
  }
  .pag-link {
    display: flex;
    flex-direction: column;
    gap: 3px;
    text-decoration: none;
    color: inherit;
    max-width: 46%;
  }
  .pag-link.next { align-items: flex-end; text-align: right; }
  .pag-dir { font-size: .8rem; opacity: .55; }
  .pag-title {
    font-size: .96rem;
    font-weight: 600;
    color: var(--accent);
    transition: opacity .15s ease;
  }
  .pag-link:hover .pag-title { opacity: .75; }

  @media (max-width: 600px) {
    .container { padding: 20px 16px 64px; }
    .highlights { grid-template-columns: 1fr 1fr; }
  }
</style>
