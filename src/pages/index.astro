---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main class="container">
      <section class="hero">
        <div class="heroText">
          <p class="kicker">Automation Software & IIoT Engineer</p>
          <h1 class="title">I build reliable shopfloor-to-cloud systems.</h1>
          <p class="subtitle">
            PLC/SCADA/MES integration, industrial networking, data collection, and Python-based tooling —
            focused on measurable production outcomes.
          </p>

          <div class="ctaRow">
            <a class="btn primary" href="/projects">View Projects</a>
            <a class="btn" href="/blog">Read Blog</a>
            <a class="btn ghost" href="/about">About</a>
          </div>

          <div class="metaRow">
            <span class="pill">PLC</span>
            <span class="pill">SCADA</span>
            <span class="pill">MES</span>
            <span class="pill">IIoT</span>
            <span class="pill">Python</span>
            <span class="pill">Node-RED</span>
            <span class="pill">SQL</span>
          </div>
        </div>

        <div class="heroCard">
          <h2 class="cardTitle">What I do</h2>
          <ul class="bullets">
            <li>PLC ↔ SCADA/MES data flows (traceability, events, KPIs)</li>
            <li>Industrial connectivity (PROFINET, TCP/IP, OPC UA, MQTT)</li>
            <li>Edge & data pipelines (Node-RED, SQL, Python, APIs)</li>
            <li>Operational tooling (monitoring, diagnostics, automation scripts)</li>
          </ul>
          <div class="miniLinks">
            <a class="link" href="/projects">See case studies →</a>
          </div>
        </div>
      </section>

      <section class="grid">
        <div class="block">
          <h2>Featured Projects</h2>
          <p class="muted">Quick case studies you can scan in minutes.</p>

          <div class="cards">
            <a class="card" href="/projects#plc-mes">
              <h3>PLC–MES Traceability Pipeline</h3>
              <p>Reliable VIN/event tracking across multiple PLCs with buffering and validation.</p>
              <p class="tag">PLC • MES • SQL • Node-RED</p>
            </a>

            <a class="card" href="/projects#scada-upgrade">
              <h3>SCADA Upgrade & Modernization</h3>
              <p>WinCC migration planning, RBAC, alarms/events, and cutover strategy.</p>
              <p class="tag">WinCC • RBAC • Deployment</p>
            </a>

            <a class="card" href="/projects#industrial-network">
              <h3>Industrial Network Troubleshooting</h3>
              <p>Root-causing intermittent comms issues and stabilizing ring topologies.</p>
              <p class="tag">SCALANCE • TCP/IP • Diagnostics</p>
            </a>
          </div>

          <div class="moreRow">
            <a class="link" href="/projects">See all projects →</a>
          </div>
        </div>

        <div class="block">
          <h2>Latest Writing</h2>
          <p class="muted">Practical notes from real engineering work.</p>

          <div class="cards">
            <a class="card" href="/blog">
              <h3>Start here: Engineering notes</h3>
              <p>Industrial IoT, PLC comms, SCADA/MES, and Python — organized by topic.</p>
              <p class="tag">Blog • Guides</p>
            </a>

            <a class="card" href="/blog">
              <h3>TSEND/TRCV patterns</h3>
              <p>How to structure robust TCP exchanges, timeouts, and recovery logic.</p>
              <p class="tag">S7-1500 • TCP</p>
            </a>

            <a class="card" href="/blog">
              <h3>WinCC Unified RBAC</h3>
              <p>Role-based access control setup that scales cleanly.</p>
              <p class="tag">HMI • Security</p>
            </a>
          </div>

          <div class="moreRow">
            <a class="link" href="/blog">Go to blog →</a>
          </div>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .container { max-width: 1120px; margin: 0 auto; padding: 40px 20px 80px; }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) minmax(0, 1fr);
    gap: 32px;
    align-items: start;
  }
  @media (max-width: 900px){
    .hero {
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }

  .kicker { margin: 0; font-weight: 600; letter-spacing: .08em; text-transform: uppercase; font-size: .8rem; opacity: .7; }
  .title { margin: 14px 0 10px; font-size: clamp(32px, 4.4vw, 54px); line-height: 1.06; letter-spacing: -.02em; }
  .subtitle { margin: 0; font-size: 1.02rem; opacity: .85; max-width: 60ch; }

  .ctaRow { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 18px; }
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 18px;
    border-radius: 999px;
    border: 1px solid rgba(148,163,184,.6);
    text-decoration: none;
    font-size: .95rem;
    font-weight: 500;
    background-color: transparent;
    color: #111827;
    transition: background-color .16s ease, color .16s ease, border-color .16s ease, transform .16s ease, box-shadow .16s ease;
  }
  .btn:hover {
    background-color: rgba(15,23,42,.03);
  }
  .btn.ghost {
    background: transparent;
    color: #111827;
  }

  .metaRow { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 18px; }
  .pill { font-size: .86rem; padding: 6px 10px; border: 1px solid rgba(148,163,184,.5); border-radius: 999px; opacity: .9; background: rgba(15,23,42,.02); }

  .heroCard {
    border-radius: 20px;
    padding: 18px 18px 16px;
    background: radial-gradient(circle at top left, rgba(59,130,246,.12), transparent 55%), rgba(15,23,42,.03);
    border: 1px solid rgba(148,163,184,.5);
    box-shadow: 0 18px 45px rgba(15,23,42,.12);
  }
  .cardTitle { margin: 0 0 12px; font-size: 1.02rem; letter-spacing: .06em; text-transform: uppercase; opacity: .8; }
  .bullets { margin: 0; padding-left: 18px; display: grid; gap: 8px; font-size: .95rem; }
  .miniLinks { display: flex; gap: 14px; margin-top: 14px; }

  .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 28px; margin-top: 40px; }
  @media (max-width: 900px){ .grid { grid-template-columns: 1fr; gap: 20px; } }

  .block h2 { margin: 0 0 6px; font-size: 1.25rem; }
  .muted { margin: 0 0 16px; opacity: .78; font-size: .96rem; }

  .cards { display: grid; gap: 14px; }
  .card {
    border: 1px solid rgba(148,163,184,.6);
    border-radius: 18px;
    padding: 16px;
    text-decoration: none;
    color: inherit;
    background: rgba(15,23,42,.01);
    transition: border-color .18s ease, background .18s ease, transform .18s ease, box-shadow .18s ease;
  }
  .card:hover {
    border-color: rgba(59,130,246,.8);
    background: rgba(37,99,235,.04);
    transform: translateY(-2px);
    box-shadow: 0 14px 32px rgba(15,23,42,.12);
  }
  .card h3 { margin: 0 0 6px; font-size: 1.05rem; }
  .card p { margin: 0; opacity: .85; }
  .tag { margin-top: 10px !important; font-size: .9rem; opacity: .75; }

  .moreRow { margin-top: 12px; }
  .link { text-decoration: none; border-bottom: 1px solid rgba(0,0,0,.25); padding-bottom: 2px; }
</style>