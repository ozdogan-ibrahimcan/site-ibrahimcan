---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { projects } from '../data/projects';

const latestPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const featuredProjects = projects.filter((p) => p.cardSummary).slice(0, 3);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main class="container">
      <section class="hero">
        <div class="heroText">
          <p class="kicker">Automation Software &amp; IIoT Engineer<br />Siemens · Istanbul</p>
          <h1 class="title">I build PLC-to-cloud systems that don't break in production.</h1>
          <p class="subtitle">
            PLC/SCADA/MES integration, industrial networking, and Python tooling —
            focused on traceability, uptime, and measurable KPIs.
          </p>

          <div class="ctaRow">
            <a class="btn primary" href="/projects">View Projects</a>
            <a class="btn" href="/blog">Read Blog</a>
          </div>

          <div class="metaRow">
            <span class="pill">S7-1500</span>
            <span class="pill">WinCC</span>
            <span class="pill">Node-RED</span>
            <span class="pill">OPC UA</span>
            <span class="pill">MQTT</span>
            <span class="pill">SQL</span>
            <span class="pill">Python</span>
          </div>
        </div>

        <div class="heroCard">
          <h2 class="cardTitle">What I deliver</h2>
          <ul class="bullets">
            <li>Traceability pipelines (VIN/event tracking, buffering, validation)</li>
            <li>SCADA modernization (WinCC migration, RBAC, alarms/events)</li>
            <li>Industrial connectivity (PROFINET/TCP, OPC UA, MQTT)</li>
            <li>Operational tooling (diagnostics, scripts, data quality checks)</li>
          </ul>
          <p class="cardNote">I document patterns and share reusable templates in the blog.</p>
          <div class="miniLinks">
            <a class="link" href="/projects">See projects →</a>
            <a class="link" href="/blog">Read blog →</a>
          </div>
        </div>
      </section>

      <section class="grid">
        <div class="block">
          <h2>Featured Projects</h2>
          <p class="muted">Case studies: problem → approach → outcome.</p>

          <div class="cards">
            {featuredProjects.map((p) => (
              <a class="card card-case-study" href={`/projects/${p.slug}`}>
                <h3>{p.title}</h3>
                {p.cardSummary && (
                  <div class="caseStudy">
                    <p class="caseStudyRow"><span class="caseStudyLabel">Problem:</span> {p.cardSummary.problem}</p>
                    <p class="caseStudyRow"><span class="caseStudyLabel">Approach:</span> {p.cardSummary.approach}</p>
                    <p class="caseStudyRow"><span class="caseStudyLabel">Outcome:</span> {p.cardSummary.outcome}</p>
                  </div>
                )}
                <p class="tag">{p.tags.slice(0, 4).join(' • ')}</p>
              </a>
            ))}
          </div>

          <div class="moreRow">
            <a class="link" href="/projects">See all projects →</a>
          </div>
        </div>

        <div class="block">
          <h2>Latest Writing</h2>
          <p class="muted">Practical notes from real engineering work.</p>

          <div class="cards">
            {latestPosts.map((post) => (
              <a class="card" href={`/blog/${post.id}/`}>
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
                <p class="tag">Blog</p>
              </a>
            ))}
          </div>

          <div class="moreRow">
            <a class="link" href="/blog">Go to blog →</a>
          </div>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .container { max-width: 1200px; margin: 0 auto; padding: var(--spacing-page); }
  @media (max-width: 600px) { .container { padding: var(--spacing-page-mobile); } }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) minmax(0, 1fr);
    gap: 32px;
    align-items: start;
  }
  @media (max-width: 900px) { .hero { grid-template-columns: 1fr; gap: 24px; } }

  .kicker { margin: 0; font-weight: 600; letter-spacing: .08em; text-transform: uppercase; font-size: .9rem; color: var(--text-muted); }
  .title { margin: 12px 0 10px; font-size: clamp(32px, 4.4vw, 54px); line-height: 1.06; letter-spacing: -.02em; }
  .subtitle { margin: 0; font-size: 1rem; color: var(--text-muted); max-width: 58ch; line-height: 1.6; }

  /* CTA buttons */
  .ctaRow { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 20px; }
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 20px;
    border-radius: var(--radius-btn);
    border: 1px solid var(--border);
    text-decoration: none;
    font-size: .92rem;
    font-weight: 500;
    background: transparent;
    color: rgb(var(--black));
    transition: background .16s ease, color .16s ease, border-color .16s ease, transform .16s ease, box-shadow .16s ease;
  }
  .btn:hover { background: rgba(15,23,42,.04); transform: translateY(-1px); }
  .btn.primary {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
    box-shadow: 0 4px 14px rgba(35,55,255,.3);
  }
  .btn.primary:hover { opacity: .88; transform: translateY(-1px); box-shadow: 0 6px 20px rgba(35,55,255,.35); }

  /* Tech pills */
  .metaRow { display: flex; flex-wrap: wrap; gap: 7px; margin-top: 16px; }
  .pill {
    font-size: .8rem;
    padding: 4px 10px;
    border: 1px solid var(--border);
    border-radius: var(--radius-btn);
    color: var(--text-muted);
    background: var(--card-bg);
  }

  /* "What I do" card */
  .heroCard {
    border-radius: var(--radius-card);
    padding: 20px;
    background: radial-gradient(circle at top left, rgba(35,55,255,.09), transparent 55%), var(--card-bg);
    border: 1px solid var(--border);
    box-shadow: 0 18px 45px rgba(15,23,42,.10);
  }
  .cardTitle { margin: 0 0 12px; font-size: .75rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: var(--text-muted); }
  .bullets { margin: 0; padding-left: 16px; display: grid; gap: 8px; font-size: .94rem; }
  .cardNote { margin: 12px 0 0; font-size: .85rem; color: var(--text-muted); line-height: 1.45; }
  .miniLinks { display: flex; flex-wrap: wrap; gap: 14px; margin-top: 12px; }

  /* Lower grid */
  .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 28px; margin-top: 44px; }
  @media (max-width: 900px) { .grid { grid-template-columns: 1fr; gap: 20px; } }

  .block h2 { margin: 0 0 4px; font-size: 1.18rem; font-weight: 700; }
  .muted { margin: 0 0 14px; color: var(--text-muted); font-size: .94rem; }

  .cards { display: grid; gap: 10px; }
  .card {
    border: 1px solid var(--border);
    border-radius: var(--radius-card);
    padding: 16px;
    text-decoration: none;
    color: inherit;
    background: var(--card-bg);
    transition: border-color .18s ease, background .18s ease, transform .18s ease, box-shadow .18s ease;
  }
  .card:hover {
    border-color: var(--border-hover);
    background: var(--card-bg-hover);
    transform: translateY(-2px);
    box-shadow: var(--card-shadow-hover);
  }
  .card h3 { margin: 0 0 5px; font-size: 1.02rem; font-weight: 600; }
  .card p { margin: 0; font-size: .92rem; color: var(--text-muted); }
  .tag { margin-top: 10px !important; font-size: .84rem; }

  .card-case-study .caseStudy { margin: 10px 0 0; display: grid; gap: 6px; }
  .card-case-study .caseStudyRow { margin: 0; font-size: .92rem; line-height: 1.5; color: var(--text-muted); }
  .card-case-study .caseStudyLabel { font-size: .8rem; font-weight: 600; letter-spacing: .05em; text-transform: uppercase; color: var(--text-muted); margin-right: 6px; }

  .moreRow { margin-top: 12px; }
  .link { text-decoration: none; border-bottom: 1px solid rgba(0,0,0,.2); padding-bottom: 2px; font-size: .92rem; }
</style>