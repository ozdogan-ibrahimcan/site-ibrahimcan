---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="tr">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="container">
			<section class="hero">
				<h1 class="title">İbrahim Can Özdogan</h1>
				<p class="subtitle">Automation Software & IIoT Engineer</p>

				<div class="photo-wrap">
					<img src="/images/biz.jpeg" alt="Ibrahim smiling" class="photo" loading="eager" />
				</div>

				<div class="intro">
					<p>Welcome to my personal site where I share technical articles, project write-ups, and career updates. Explore below to learn more about my work and experience.</p>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.container {
		max-width: 960px;
		margin: 0 auto;
		padding: 32px 16px 64px;
	}
	.hero {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 12px;
	}
	.title {
		text-align: center;
		font-size: clamp(28px, 5vw, 44px);
		margin: 12px 0 0;
	}
	.subtitle {
		margin: 0;
		opacity: 0.8;
	}
	.photo-wrap {
		width: 100%;
		display: flex;
		justify-content: center;
		margin-top: 16px;
	}
	.photo {
		width: min(820px, 96%);
		height: auto;
		border-radius: 18px;
		box-shadow: 0 14px 40px rgba(0, 0, 0, 0.18);
	}
	.intro {
		max-width: 640px;
		text-align: center;
		margin-top: 24px;
		font-size: 1.05em;
		line-height: 1.6;
	}
</style>