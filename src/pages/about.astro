---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`${SITE_TITLE} | About`} description="Background, education, and professional experience." />
  </head>

  <body>
    <Header />

    <main class="container">
      <header class="top">
        <h1>About</h1>
        <p class="lead">
          Automation Software & IIoT Engineer focused on industrial digitalization — building reliable data
          systems from PLC/SCADA to MES and higher-level platforms.
        </p>
      </header>

      <section class="section">
        <h2>Professional Experience</h2>

        <div class="card">
          <h3>Siemens Turkey — Automation Software & IoT Engineer</h3>
          <p class="meta">Jul 2022 – Present</p>
          <ul>
            <li>Designed and delivered production data integration systems between PLCs, SCADA platforms, and MES environments.</li>
            <li>Developed Node-RED architectures, SQL-based data layers, and backend logic for scalable real-time communication.</li>
            <li>Built control APIs and automation workflows in complex robotic welding environments.</li>
            <li>Implemented predictive maintenance systems using Grafana dashboards, Node-RED flows, and Linux-based IoT gateways.</li>
          </ul>
        </div>

        <div class="card">
          <h3>Akerasoft — Embedded Systems Intern</h3>
          <p class="meta">Oct 2021 – Apr 2022</p>
          <ul>
            <li>Worked on microcontroller-based firmware and hardware development (Embedded C/C++).</li>
            <li>Assisted with schematic design and PCB layout using KiCad; supported device-level debugging and documentation.</li>
          </ul>
        </div>
      </section>

      <section class="section">
        <h2>Education</h2>

        <div class="card">
          <h3>Istanbul Technical University — M.Sc., Computer Engineering</h3>
          <p class="meta">Sep 2024 – Present</p>
          <p class="muted">
            Interests: IoT architectures, smart manufacturing systems, industrial automation software, edge computing.
          </p>
        </div>

        <div class="card">
          <h3>Istanbul Technical University — B.Sc., Electrical Engineering</h3>
          <p class="meta">Sep 2018 – Jun 2023</p>
          <p class="muted">
            Graduated top of class (GPA 3.81/4.00). Focused on power electronics, embedded systems, PLC/SCADA technologies,
            and industrial automation.
          </p>
        </div>
      </section>

      <section class="section">
        <h2>Core Skills</h2>
        <div class="skills">
          <span class="pill">TIA Portal (S7-1500)</span>
          <span class="pill">SCL</span>
          <span class="pill">WinCC</span>
          <span class="pill">OPC UA</span>
          <span class="pill">PROFINET</span>
          <span class="pill">Node-RED</span>
          <span class="pill">MQTT</span>
          <span class="pill">Python</span>
          <span class="pill">SQL</span>
          <span class="pill">Linux</span>
          <span class="pill">Docker</span>
          <span class="pill">Git</span>
        </div>
      </section>

      <div class="ctaRow">
        <a class="link accent" href="/contact">Get in touch →</a>
      </div>
    </main>

    <Footer />
  </body>
</html>

<style>
  .container { max-width: 960px; margin: 0 auto; padding: 40px 32px 80px; }
  @media (max-width: 600px) { .container { padding: 24px 16px 60px; } }
  .top { margin-bottom: 24px; }
  .lead { margin: 10px 0 0; opacity: .85; max-width: 70ch; font-size: 1.02rem; }

  .section { margin-top: 28px; }
  .section h2 { margin: 0 0 12px; font-size: 1.25rem; color: rgb(var(--black)); }
  .card {
    border: 1px solid rgba(148, 163, 184, .6);
    border-radius: 18px;
    padding: 16px;
    margin-top: 12px;
    background: rgba(15, 23, 42, .01);
    transition: border-color .18s ease, background .18s ease, box-shadow .18s ease;
  }
  .card:hover {
    border-color: rgba(59, 130, 246, .5);
    background: rgba(37, 99, 235, .03);
    box-shadow: 0 14px 32px rgba(15, 23, 42, .08);
  }
  .meta { margin: 6px 0 10px; opacity: .75; font-size: .95rem; }
  .muted { opacity: .85; margin: 0; }

  ul { margin: 0; padding-left: 18px; display: grid; gap: 8px; }

  .skills { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 12px; }
  .pill {
    font-size: .86rem;
    padding: 6px 10px;
    border: 1px solid rgba(148, 163, 184, .5);
    border-radius: 999px;
    opacity: .9;
    background: rgba(15, 23, 42, .02);
  }

  .ctaRow { margin-top: 28px; }
  .link { text-decoration: none; border-bottom: 1px solid rgba(0, 0, 0, .25); padding-bottom: 2px; }
  .link.accent { color: var(--accent); border-bottom-color: var(--accent); }
</style>