---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { CV_URL, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`${SITE_TITLE} | About`} description="Background, education, and professional experience." />
  </head>

  <body>
    <Header />

    <main class="container">
      <header class="top">
        <p class="kicker">About</p>
        <h1>Ibrahim Can Ozdogan</h1>
        <p class="story">
          I'm an Automation Software & IIoT Engineer at Siemens, focused on turning shopfloor signals into reliable production data.
        </p>
        <p class="story">
          I work on PLC/SCADA/MES integration, industrial networking, and edge data pipelines — with an emphasis on traceability, uptime, and measurable KPIs.
        </p>
      </header>

      <section class="section">
        <h2>Experience</h2>

        <div class="card">
          <h3>Siemens — Automation & digitalization</h3>
          <p class="meta">Jul 2022 – Present</p>
          <ul>
            <li>Production data integration between PLCs, SCADA, and MES; Node-RED and SQL-based pipelines.</li>
            <li>Control APIs and automation workflows in robotic welding; predictive maintenance with Grafana and edge gateways.</li>
          </ul>
        </div>

        <div class="card">
          <h3>Akerasoft — Embedded systems</h3>
          <p class="meta">Oct 2021 – Apr 2022</p>
          <ul>
            <li>Embedded C/C++ firmware; KiCad schematic and PCB; device-level debugging and documentation.</li>
          </ul>
        </div>
      </section>

      <section class="section">
        <h2>Education</h2>
        <ul class="eduList">
          <li><strong>Istanbul Technical University</strong> — M.Sc. Computer Engineering (in progress)</li>
          <li><strong>Istanbul Technical University</strong> — B.Sc. Electrical Engineering (GPA 3.81, top of class)</li>
        </ul>
      </section>

      <section class="section">
        <h2>Certifications</h2>
        <p class="certs">CCNA, S7-1500, SCL, First Aid</p>
      </section>

      <p class="cvLink">
        <a class="link" href={CV_URL} target="_blank" rel="noreferrer">Download Resume (PDF)</a>
      </p>
    </main>

    <Footer />
  </body>
</html>

<style>
  .container { max-width: 960px; margin: 0 auto; padding: var(--spacing-page); }
  @media (max-width: 600px) { .container { padding: var(--spacing-page-mobile); } }

  .top { margin-bottom: 28px; }
  .kicker { margin: 0 0 8px; font-size: .78rem; font-weight: 600; letter-spacing: .1em; text-transform: uppercase; color: var(--text-muted); }
  .story { margin: 10px 0 0; color: var(--text-muted); max-width: 68ch; font-size: 1rem; line-height: 1.65; }

  .section { margin-top: 32px; }
  .section h2 { margin: 0 0 12px; font-size: 1.18rem; font-weight: 700; color: rgb(var(--black)); }
  .card {
    border: 1px solid var(--border);
    border-radius: var(--radius-card);
    padding: 16px 18px;
    margin-top: 10px;
    background: var(--card-bg);
    transition: border-color .18s ease, background .18s ease, box-shadow .18s ease;
  }
  .card:hover {
    border-color: var(--border-hover);
    background: var(--card-bg-hover);
    box-shadow: var(--card-shadow-hover);
  }
  .meta { margin: 4px 0 10px; color: var(--text-muted); font-size: .9rem; }
  .muted { color: var(--text-muted); margin: 0; font-size: .94rem; }

  ul { margin: 0; padding-left: 18px; display: grid; gap: 7px; font-size: .94rem; }

  .eduList { list-style: none; padding-left: 0; }
  .eduList li { margin-bottom: 8px; font-size: .94rem; color: var(--text-muted); }
  .certs { margin: 0; font-size: .94rem; color: var(--text-muted); }
  .cvLink { margin-top: 24px; }
  .link { text-decoration: none; border-bottom: 1px solid rgba(0, 0, 0, .2); padding-bottom: 2px; font-size: .92rem; }
</style>