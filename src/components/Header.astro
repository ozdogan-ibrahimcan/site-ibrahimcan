---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';

const LINKEDIN_URL = "https://www.linkedin.com/in/ibrahimcanozdogan/";
const GITHUB_URL = "https://github.com/ozdogan-ibrahimcan";
const EMAIL = "mailto:ozdoganic@gmail.com";
const CV_URL = "/ibrahimcan_ozdogan_CV.pdf";
---
<header>
  <nav>
    <h2><a href="/">{SITE_TITLE}</a></h2>

    <div class="internal-links">
      <HeaderLink href="/">Home</HeaderLink>
      <HeaderLink href="/projects">Projects</HeaderLink>
      <HeaderLink href="/blog">Blog</HeaderLink>
      <HeaderLink href="/about">About</HeaderLink>
    </div>

    <div class="social-links">
      <a class="icon-btn" href={LINKEDIN_URL} target="_blank" rel="noreferrer" aria-label="LinkedIn" title="LinkedIn">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path fill="currentColor" d="M20.45 20.45h-3.56v-5.57c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.95v5.66H9.35V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.26 2.37 4.26 5.45v6.29zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM3.56 20.45h3.56V9H3.56v11.45z"/>
        </svg>
      </a>

      <a class="icon-btn" href={GITHUB_URL} target="_blank" rel="noreferrer" aria-label="GitHub" title="GitHub">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path fill="currentColor" d="M12 .5C5.73.5.75 5.48.75 11.75c0 4.9 3.18 9.06 7.59 10.53.55.1.75-.24.75-.53v-1.9c-3.09.68-3.74-1.31-3.74-1.31-.5-1.27-1.22-1.61-1.22-1.61-1-.68.08-.67.08-.67 1.1.08 1.68 1.13 1.68 1.13.98 1.67 2.57 1.19 3.2.91.1-.71.38-1.19.68-1.47-2.47-.28-5.06-1.23-5.06-5.49 0-1.21.43-2.2 1.13-2.98-.11-.28-.49-1.41.11-2.94 0 0 .92-.3 3.02 1.14.88-.24 1.82-.36 2.76-.36s1.88.12 2.76.36c2.1-1.44 3.02-1.14 3.02-1.14.6 1.53.22 2.66.11 2.94.7.78 1.13 1.77 1.13 2.98 0 4.27-2.6 5.21-5.08 5.49.39.34.74 1 .74 2.02v2.99c0 .29.2.64.76.53 4.41-1.47 7.58-5.63 7.58-10.53C23.25 5.48 18.27.5 12 .5z"/>
        </svg>
      </a>

      <a class="icon-btn" href={EMAIL} aria-label="Email" title="Email">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path fill="currentColor" d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"/>
        </svg>
      </a>

      <!-- CV: always open in new tab -->
      <a class="cv-btn" href={CV_URL} target="_blank" rel="noreferrer" aria-label="Open CV" title="Open CV">
        CV
      </a>

    </div>
  </nav>
</header>

<style>
  header {
    margin: 0;
    padding: 0 1em;
    background: white;
    box-shadow: 0 2px 8px rgba(var(--black), 5%);
  }

  h2 { margin: 0; font-size: 1em; white-space: nowrap; }
  h2 a { text-decoration: none; color: var(--black); }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .internal-links {
    display: flex;
    align-items: center;
    gap: 2px;
    flex-wrap: wrap;
  }

  nav a {
    padding: 1em 0.5em;
    color: var(--black);
    border-bottom: 4px solid transparent;
    text-decoration: none;
  }

  nav a.active { border-bottom-color: var(--accent); }

  .social-links {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .icon-btn {
    padding: 6px;
    border: none;
    background: transparent;
    border-radius: 10px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
    text-decoration: none;
    opacity: 0.78;
    transition: opacity 150ms ease, transform 150ms ease, background-color 150ms ease;
  }

  .icon-btn:hover {
    opacity: 1;
    transform: translateY(-1px);
    background: rgba(0, 0, 0, 0.04);
  }

  .icon-btn svg {
    width: 20px;
    height: 20px;
    display: block;
  }

  .cv-btn {
    padding: 8px 10px;
    border: 1px solid rgba(0, 0, 0, 0.12);
    border-radius: 12px;
    text-decoration: none;
    font-size: 0.9rem;
    line-height: 1;
    opacity: 0.9;
    transition: opacity 150ms ease, transform 150ms ease, background-color 150ms ease, border-color 150ms ease;
  }

  .cv-btn:hover {
    opacity: 1;
    transform: translateY(-1px);
    background: rgba(0, 0, 0, 0.04);
    border-color: rgba(0, 0, 0, 0.18);
  }

  @media (max-width: 900px) {
    .social-links { display: none; }
  }
</style>